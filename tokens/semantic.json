{
  "_comment": "Tier 2 — role-based aliases pointing at primitives. Components reference THESE (via the matching CSS var in app/globals.css). Theme files override the theme-dependent ones.",
  "color": {
    "bg.canvas": "{palette.cream.canvas}",
    "surface.soft": "{palette.cream.soft}",
    "surface.card": "{palette.cream.card}",
    "surface.strong": "{palette.cream.strong}",
    "panel.bg": "#fffefa",
    "panel.bg.strong": "{palette.cream.strong}",
    "fg.ink": "{palette.ink}",
    "fg.body": "#2a2a2a",
    "fg.muted": "#595959",
    "fg.muted.soft": "#6a6a6a",
    "hairline.default": "#e6dfc8",
    "hairline.strong": "#d6cfb5",
    "accent.primary": "{palette.ink}",
    "accent.onPrimary": "{palette.white}"
  },
  "severity": {
    "critical.fill": "{palette.red.600}",
