    "critical.on": "{palette.white}",
    "critical.bg": "{palette.red.tintLight}",
    "high.fill": "{palette.brand.coral}",
    "high.text": "#a3331f",
    "high.bg": "#fbe5e0",
    "medium.fill": "{palette.brand.ochre}",
    "medium.text": "#8a5e0e",
    "medium.bg": "#fbf0d4",
    "low.fill": "{palette.brand.blue}",
    "low.text": "#1e40af",
